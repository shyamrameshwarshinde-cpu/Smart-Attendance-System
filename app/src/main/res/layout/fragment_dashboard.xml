<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F7FB">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- HEADER IMAGE -->
        <ImageView
            android:id="@+id/headerImage"
            android:layout_width="0dp"
            android:layout_height="220dp"
            android:scaleType="centerCrop"
            android:src="@drawable/login_top_image"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- GREETING -->
        <TextView
            android:id="@+id/txtGreeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Good Afternoon, Teacher"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/purple_main"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/headerImage"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- ===== STATS ===== -->
        <LinearLayout
            android:id="@+id/statsSection"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="16dp"
            app:layout_constraintTop_toBottomOf="@id/txtGreeting"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- ROW 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    style="@style/statCard"
                    android:layout_width="0dp"
                    android:layout_weight="1">

                    <TextView
                        style="@style/statTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Classes"/>

                    <TextView
                        style="@style/statValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4"/>
                </LinearLayout>

                <LinearLayout
                    style="@style/statCard"
                    android:layout_width="0dp"
                    android:layout_weight="1">

                    <TextView
                        style="@style/statTitle"
                        android:text="Total Students"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        style="@style/statValue"
                        android:text="92"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

            </LinearLayout>

            <!-- ROW 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    style="@style/statCard"
                    android:layout_width="0dp"
                    android:layout_weight="1">

                    <TextView
                        style="@style/statTitle"
                        android:text="Present Today"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        style="@style/statValue"
                        android:text="84"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <LinearLayout
                    style="@style/statCard"
                    android:layout_width="0dp"
                    android:layout_weight="1">

                    <TextView
                        style="@style/statTitle"
                        android:text="Absent Today"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        style="@style/statValue"
                        android:text="8"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- ===== ACTION BUTTONS ===== -->
        <LinearLayout
            android:id="@+id/actionSection"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="16dp"
            app:layout_constraintTop_toBottomOf="@id/statsSection"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">


            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnCreateClass"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_create_account_btn"
                android:backgroundTint="@null"
                android:fontFamily="@font/poppins_medium"
                android:text="Create Class"
                android:textAllCaps="false"
                android:textColor="#7B4DFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnStartAttendance"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_create_account_btn"
                android:backgroundTint="@null"
                android:fontFamily="@font/poppins_medium"
                android:text="Start Attedance"
                android:textAllCaps="false"
                android:textColor="#7B4DFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnReports"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_create_account_btn"
                android:backgroundTint="@null"
                android:fontFamily="@font/poppins_medium"
                android:text="Export Excel / Reports"
                android:textAllCaps="false"
                android:textColor="#7B4DFF"
                android:textSize="18sp"
                android:textStyle="bold" />



            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnManual"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_create_account_btn"
                android:backgroundTint="@null"
                android:fontFamily="@font/poppins_medium"
                android:text="Manual Attedance"
                android:textAllCaps="false"
                android:textColor="#7B4DFF"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- TODAY TITLE -->
        <TextView
            android:id="@+id/todayTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Today's Classes"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/purple_main"
            android:layout_marginStart="16dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/actionSection"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- CLASS LIST -->
        <LinearLayout
            android:id="@+id/classList"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="16dp"
            app:layout_constraintTop_toBottomOf="@id/todayTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout style="@style/classCard">

                <TextView
                    style="@style/classTitle"
                    android:text="Math Class"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="Room 101"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="10:00 AM - 11:00 AM"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <LinearLayout style="@style/classCard">

                <TextView
                    style="@style/classTitle"
                    android:text="Science Class"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="Lab 202"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="1:00 PM - 2:00 PM"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>