<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- PAGE TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Classroom Location"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="@font/poppins_semibold"
            android:textColor="#4A3AFF"
            android:layout_marginBottom="16dp"/>

        <!-- LOCATION NAME CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Classroom Name"
                    android:textStyle="bold"
                    android:fontFamily="@font/poppins_semibold"
                    android:textSize="14sp"/>

                <EditText
                    android:id="@+id/etLocationName"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Example: Room 101"
                    android:background="@android:drawable/edit_text"
                    android:padding="10dp"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- GPS STATUS CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GPS Status"
                    android:textStyle="bold"
                    android:fontFamily="@font/poppins_semibold"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/tvGpsStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Waiting for location..."
                    android:textColor="#2196F3"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- GET LOCATION BUTTON -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnGetLocation"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Get Current Location"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/poppins_semibold"
            android:textSize="16sp"
            android:layout_marginTop="24dp"
            android:background="@drawable/login_btn_gradient"/>


        <!-- SAVE LOCATION BUTTON -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSaveLocation"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Save Classroom Location"
            android:fontFamily="@font/poppins_semibold"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_marginTop="12dp"
            android:background="@drawable/login_btn_gradient"
            />

    </LinearLayout>

</ScrollView>