<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4FF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ══════════════════════════════════ -->
        <!--         DEEP TEAL HEADER          -->
        <!-- ══════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/teacher_header_gradient"
            android:paddingBottom="44dp">

            <!-- Avatar Ring -->
            <FrameLayout
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_gravity="center">

                <View
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:background="@drawable/teacher_avatar_ring" />

                <ImageView
                    android:id="@+id/ivTeacherAvatar"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:layout_gravity="center"
                    android:src="@mipmap/ic_launcher"
                    android:scaleType="centerCrop"
                    android:contentDescription="Teacher Avatar"
                    android:background="@drawable/teacher_avatar_bg"
                    android:clipToOutline="true"
                    android:outlineProvider="background" />

            </FrameLayout>

            <!-- Teacher Name -->
            <TextView
                android:id="@+id/tvTeacherName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loading..."
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="10dp" />

            <!-- Role Badge -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👨‍🏫  TEACHER"
                android:textColor="#B2EBF2"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginTop="4dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:background="@drawable/teacher_badge_bg" />

        </LinearLayout>

        <!-- ══════════════════════════════════ -->
        <!--         INFO CARD                 -->
        <!-- ══════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/teacher_card_bg"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            android:layout_marginTop="-28dp"
            android:elevation="10dp"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <!-- Section Label -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="18dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="18dp"
                    android:background="#00838F"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PROFILE INFORMATION"
                    android:textColor="#00838F"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.10" />
            </LinearLayout>

            <!-- Full Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Full Name"
                android:textColor="#9E9E9E"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginBottom="5dp" />

            <EditText
                android:id="@+id/etTeacherName"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Enter full name"
                android:textColor="#1A1A2E"
                android:textSize="15sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/teacher_input_bg"
                android:inputType="textPersonName"
                android:layout_marginBottom="16dp" />

            <!-- Email -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email Address"
                android:textColor="#9E9E9E"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginBottom="5dp" />

            <EditText
                android:id="@+id/etTeacherEmail"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Email"
                android:textColor="#AAAAAA"
                android:textSize="15sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/teacher_input_disabled_bg"
                android:enabled="false"
                android:inputType="textEmailAddress"
                android:layout_marginBottom="16dp" />

            <!-- Department -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Department"
                android:textColor="#9E9E9E"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginBottom="5dp" />

            <EditText
                android:id="@+id/etDepartment"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="e.g. Computer Science"
                android:textColor="#1A1A2E"
                android:textSize="15sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/teacher_input_bg"
                android:inputType="textCapWords"
                android:layout_marginBottom="16dp" />

            <!-- Subject Specialization -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Subject Specialization"
                android:textColor="#9E9E9E"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginBottom="5dp" />

            <EditText
                android:id="@+id/etSubject"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="e.g. Data Structures"
                android:textColor="#1A1A2E"
                android:textSize="15sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/teacher_input_bg"
                android:inputType="textCapWords"
                android:layout_marginBottom="16dp" />

            <!-- Employee ID -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Employee ID"
                android:textColor="#9E9E9E"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginBottom="5dp" />

            <EditText
                android:id="@+id/etEmployeeId"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="e.g. TCH-2024-001"
                android:textColor="#1A1A2E"
                android:textSize="15sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/teacher_input_bg"
                android:inputType="text"
                android:layout_marginBottom="4dp" />

        </LinearLayout>

        <!-- ══════════════════════════════════ -->
        <!--         STATS ROW                 -->
        <!-- ══════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            android:layout_marginTop="16dp">

            <!-- Classes Created -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/teacher_card_bg"
                android:elevation="4dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:layout_marginEnd="8dp">

                <TextView
                    android:id="@+id/tvClassCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#00838F"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Classes"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Students Total -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/teacher_card_bg"
                android:elevation="4dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp">

                <TextView
                    android:id="@+id/tvStudentCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#00838F"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Students"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Attendance Records -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/teacher_card_bg"
                android:elevation="4dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:layout_marginStart="8dp">

                <TextView
                    android:id="@+id/tvAttendanceCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#00838F"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Records"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp" />
            </LinearLayout>

        </LinearLayout>

        <!-- ══════════════════════════════════ -->
        <!--         ACTION BUTTONS            -->
        <!-- ══════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="20dp"
            android:paddingBottom="16dp">

            <Button
                android:id="@+id/btnEditTeacherProfile"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="✏️  Edit Profile"
                android:textColor="#00838F"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/teacher_btn_outline"
                android:layout_marginBottom="12dp"
                android:elevation="0dp" />

            <Button
                android:id="@+id/btnSaveTeacherProfile"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="💾  Save Profile"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/teacher_btn_save"
                android:layout_marginBottom="12dp"
                android:elevation="4dp" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginBottom="12dp" />

            <!-- Logout -->
            <Button
                android:id="@+id/btnlogoutteacher"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🚪  Logout"
                android:textColor="#D32F2F"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/teacher_btn_logout"
                android:elevation="0dp" />

        </LinearLayout>

        <!-- Bottom spacing -->
        <View
            android:layout_width="match_parent"
            android:layout_height="24dp" />

    </LinearLayout>

</ScrollView>