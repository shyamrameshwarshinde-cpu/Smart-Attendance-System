<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background -->
    <solid android:color="#F3F0FF"/>

    <!-- Border -->
    <stroke
        android:width="2dp"
        android:color="#7B4DFF"/>

    <!-- Rounded corners -->
    <corners android:radius="30dp"/>

    <!-- Padding inside -->
    <padding
        android:left="16dp"
        android:right="16dp"
        android:top="12dp"
        android:bottom="12dp"/>

</shape>